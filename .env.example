# ===== 应用 =====
APP_NAME=know-agent
APP_ENV=dev
APP_PORT=8000

# ===== 认证 — API Key 头校验（AUTH_ENABLED=false 时旁路，生产建议开启）=====
AUTH_ENABLED=false
API_KEY=
# Casdoor（OIDC）— AUTH_ENABLED=true 且 CASDOOR_ENABLED=true 时启用 JWT 认证
# 方式 A：后端调 Casdoor /api/userinfo 验证 Bearer token，提取用户角色
CASDOOR_ENABLED=false
CASDOOR_ENDPOINT=
CASDOOR_USERINFO_PATH=/api/userinfo
CASDOOR_ROLES_FIELD=roles
CASDOOR_TOKEN_CACHE_TTL=300
# 应用凭证 + 组织（client credentials 列角色，上传时选择可见角色用）
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORG=
# CORS 允许源，逗号分隔；默认 * 开发友好，生产应配白名单
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ORIGINS=*

# ===== 文件上传安全 =====
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=pdf,doc,docx,txt,md,markdown,html,htm,csv,xlsx,xls

# ===== LLM — DeepSeek (OpenAI 兼容) =====
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== Embedding — 火山方舟 Doubao (OpenAI 兼容) =====
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_EMBEDDING_MODEL=doubao-embedding-vision
EMBEDDING_DIMENSIONS=2048

# ===== PostgreSQL — 业务数据 + pgvector 向量 + pg_trgm 关键词 + langgraph checkpoint =====
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/know_agent

# ===== RustFS — S3 兼容对象存储 =====
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# ===== Jina MCP (搜索) + Rerank (复用同一 KEY) =====
JINA_API_KEY=
JINA_MCP_URL=https://mcp.jina.ai/sse

# ===== RAG pipeline（生产级检索，均有默认值，按需调整）=====
# 最终返回片段数
RAG_TOP_K=5
# 重排序前候选池大小（越大召回越多，rerank 成本越高）
RAG_CANDIDATE_POOL=20
# 多查询改写（LLM 生成多视角查询扩大召回）
RAG_MULTI_QUERY=true
# HyDE 假设性文档嵌入（LLM 先生成假设答案再做向量检索）
RAG_HYDE=true
# Jina cross-encoder 重排序（无 JINA_API_KEY 或调用失败自动降级为 RRF 排序）
RAG_RERANK=true
RAG_RERANK_MODEL=jina-reranker-v2-base-multilingual

# ===== API 限流（slowapi，按 IP，保护 agent/graph 高成本端点）=====
RATE_LIMIT=60/minute

# ===== HITL 工具审批（逗号分隔工具名，调用前 interrupt 等审批；空=不启用）=====
HITL_TOOLS=

# ===== 可观测性 — LangSmith tracing（langchain 内置，开启后所有 LLM/agent/工具调用自动上报）=====
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=know-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
